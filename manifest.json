{
  "manifest_version": 3,
  "name": "Hallmark Price Protection Autofill",
  "description": "Securely store and autofill personal details for price protection claim forms.",
  "version": "0.1.0",
  "permissions": ["storage", "tabs", "alarms"],
  "action": {
    "default_title": "Price Protection Autofill",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://maplc.outsystemsenterprise.com/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}
